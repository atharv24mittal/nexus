# Copy this file to .env and fill in your own values. Never commit .env itself.

# --- LLM provider (pick ONE) ---
# Free, fast, recommended: get a key in ~30 seconds at https://console.groq.com
GROQ_API_KEY=
# Alternative provider:
OPENAI_API_KEY=

# Model name (must match whichever provider you configured above)
LLM_MODEL=llama-3.3-70b-versatile

# --- Agent behaviour ---
MAX_REPAIR_ATTEMPTS=5
SKILL_LIBRARY_FEW_SHOT_K=2

# --- API / security ---
# Comma-separated list of frontend origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
RATE_LIMIT_SOLVE_MAX=10
RATE_LIMIT_SOLVE_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_MAX=60
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
MAX_REQUEST_BODY_BYTES=20000
DISABLE_DOCS=false
ENVIRONMENT=development
